<?xml version="1.0" encoding="UTF-8"?>
<project name="algotris" default="run" basedir=".">

    <property name="src.dir" value="src"/>
    <!--<property name="test.dir" value="src/blackjack/test"/>-->
    <property name="build.dir" value="build"/>
    <!--<property name="test.build.dir" value="test-build"/>-->
    <property name="jar.file" value="algotris.jar"/>


    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${test.build.dir}"/>
    </target>

    <target name="compile" depends="clean">
        <mkdir dir="${build.dir}"/>
        <javac
            srcdir="${src.dir}"
            destdir="${build.dir}"
            includeantruntime="false">
        </javac>
    </target>

    <target name="jar" depends="compile">
        <mkdir dir="dist"/>

        <jar destfile="dist/${jar.file}" basedir="${build.dir}">
            <manifest>
                <attribute name="Main-Class" value="visualizer.MainMenu"/>
            </manifest>
        </jar>

        <echo>algotris.jar created.</echo>
    </target>

    <!-- RUN APPLICATION -->
    <target name="run" depends="jar">
        <java fork="true" classname="visualizer.MainMenu">
            <classpath>
                <pathelement path="dist/${jar.file}"/>
            </classpath>
        </java>
    </target>

